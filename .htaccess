RewriteEngine On

# ── Force HTTPS ──
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── Block WordPress/CMS scanner bots ──
RewriteRule ^wp-admin - [F,L]
RewriteRule ^wp-login - [F,L]
RewriteRule ^wp-content - [F,L]
RewriteRule ^wp-includes - [F,L]
RewriteRule ^wordpress - [F,L]
RewriteRule ^xmlrpc\.php - [F,L]
RewriteRule ^\.env - [F,L]
RewriteRule ^\.git - [F,L]
RewriteRule ^phpmyadmin - [F,L]

# ── Block common attack paths & scanners ──
RewriteRule ^(\.ht|\.user\.ini|composer\.(json|lock)|vendor/) - [F,L]
RewriteRule ^(config|backup|dump|sql|db|database|temp|tmp)/ - [F,L]
RewriteRule ^.*\.(bak|old|orig|save|swp|swo|sql|tar|gz|zip|rar|7z|log|ini)$ - [F,L]
RewriteRule ^(migrations|cache|includes)/.*$ - [F,L]

# ── Block direct access to sensitive PHP files ──
RewriteRule ^includes/ - [F,L]
RewriteRule ^migrations/ - [F,L]

# ── Block suspicious query strings (SQL injection attempts) ──
RewriteCond %{QUERY_STRING} (union|select|insert|delete|drop|update|alter|create|exec|script|javascript|vbscript) [NC]
RewriteCond %{QUERY_STRING} (;|'|--|/\*|\*/|0x|char\(|concat\(|benchmark\() [NC]
RewriteRule .* - [F,L]

# ── Block suspicious user agents (common scanners) ──
RewriteCond %{HTTP_USER_AGENT} (sqlmap|nikto|nmap|dirbuster|gobuster|havij|w3af|acunetix|nessus|openvas) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (masscan|zmeu|morfeus|zollard) [NC]
RewriteRule .* - [F,L]

# Allow access to files and directories if they exist
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f

# Sitemap Rewrite
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# Menu System - /menu/123 -> menu.php?id=123
RewriteRule ^menu/([0-9]+)$ menu.php?id=$1 [L,QSA]

# If the request points to a .php file that exists, serve it
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]

# Gzip Compression
<IfModule mod_deflate.c>
    # Compress HTML, CSS, JavaScript, Text, XML and fonts
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/vnd.ms-fontobject
    AddOutputFilterByType DEFLATE application/x-font
    AddOutputFilterByType DEFLATE application/x-font-opentype
    AddOutputFilterByType DEFLATE application/x-font-otf
    AddOutputFilterByType DEFLATE application/x-font-truetype
    AddOutputFilterByType DEFLATE application/x-font-ttf
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE font/opentype
    AddOutputFilterByType DEFLATE font/otf
    AddOutputFilterByType DEFLATE font/ttf
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE image/x-icon
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml

    # Remove browser bugs (only needed for really old browsers)
    BrowserMatch ^Mozilla/4 gzip-only-text/html
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
    Header append Vary User-Agent
</IfModule>

# Browser Caching
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    
    # CSS & JS
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    
    # Fonts
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
</IfModule>

# Cache-Control Headers & Security Headers
<IfModule mod_headers.c>
    <FilesMatch "\.(ico|pdf|flv|jpg|jpeg|png|gif|webp|svg|js|css|swf)$">
        Header set Cache-Control "max-age=31536000, public"
    </FilesMatch>
    
    # Security Headers for all responses
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(self), microphone=(self), camera=(self)"
    Header set X-XSS-Protection "1; mode=block"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    
    # Prevent PHP version disclosure
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# ── Prevent directory listing ──
Options -Indexes

# ── Block access to sensitive files ──
<FilesMatch "\.(env|log|ini|bak|sql|sh|yml|yaml|toml|lock)$">
    Require all denied
</FilesMatch>

# ── Protect includes and config files ──
<FilesMatch "^(db|config|bootstrap|security_helper|auth_helper|cache_helper|RateLimiter)\.php$">
    Require all denied
</FilesMatch>

# ── Limit upload file size (10MB) ──
LimitRequestBody 10485760

# ── Disable server signature ──
ServerSignature Off

# PHP Session Configuration (30 Days)
<IfModule mod_php.c>
    php_value session.gc_maxlifetime 2592000
    php_value session.cookie_lifetime 2592000
</IfModule>

# Custom Error Pages
ErrorDocument 403 /403.php
ErrorDocument 404 /404.php
